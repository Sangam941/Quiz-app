{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Subject": {
      "title": "Subject",
      "description": "BBA Subjects",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Topic": {
      "title": "Topic",
      "description": "Topic within a subject",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subjectId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subjectId", "name"]
    },
    "Question": {
      "title": "Question",
      "description": "Multiple choice question",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topicId": { "type": "string" },
        "subjectId": { "type": "string" },
        "text": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswerIndex": { "type": "integer" },
        "explanation": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "status": { "type": "string", "enum": ["pending", "published"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subjectId", "text", "options", "correctAnswerIndex", "difficulty", "status"]
    },
    "Attempt": {
      "title": "Attempt",
      "description": "Record of a quiz attempt",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "subjectId": { "type": "string" },
        "score": { "type": "integer" },
        "totalQuestions": { "type": "integer" },
        "answers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "questionId": { "type": "string" },
              "selectedIndex": { "type": "integer" },
              "isCorrect": { "type": "boolean" }
            }
          }
        },
        "timeTaken": { "type": "integer" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "score", "totalQuestions", "startedAt", "completedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "BBA subjects"
    },
    "/subjects/{subjectId}/topics/{topicId}": {
      "schema": "Topic",
      "description": "Topics within subjects"
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "All practice questions"
    },
    "/attempts/{attemptId}": {
      "schema": "Attempt",
      "description": "User quiz attempts"
    }
  }
}
